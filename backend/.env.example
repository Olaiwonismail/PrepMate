# Google Gemini API key — used for question generation, follow-up, and debrief
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key — used for TTS and STT
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ID — default voice used for TTS
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
